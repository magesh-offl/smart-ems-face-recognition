{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "args": [
                "app.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "jinja": true,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "name": "Inference Service: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "python": "${workspaceFolder}/inference_service/venv/bin/python",
            "args": [
                "app.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8010"
            ],
            "jinja": true,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/inference_service"
            },
            "cwd": "${workspaceFolder}/inference_service",
            "console": "integratedTerminal"
        },
        {
            "name": "Backend: Webcam Recognition",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "program": "${workspaceFolder}/backend/scripts/recognize.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Backend: Add Persons",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "program": "${workspaceFolder}/backend/scripts/add_persons.py",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Frontend: Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src",
            "runtimeExecutable": "stable",
            "preLaunchTask": "Start Frontend",
            "postDebugTask": "Stop Frontend",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/*"
            }
        },
        {
            "name": "Frontend: Edge",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src",
            "preLaunchTask": "Start Frontend",
            "sourceMaps": true
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: All Services",
            "configurations": [
                "Backend: FastAPI",
                "Inference Service: FastAPI",
                "Frontend: Chrome"
            ],
            "stopAll": true
        },
        {
            "name": "Services: Backend & Inference",
            "configurations": [
                "Backend: FastAPI",
                "Inference Service: FastAPI"
            ],
            "stopAll": true
        },
        {
            "name": "Full Stack: Debug Both",
            "configurations": [
                "Backend: FastAPI",
                "Frontend: Chrome"
            ],
            "stopAll": true
        }
    ]
}