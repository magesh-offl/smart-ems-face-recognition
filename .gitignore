# Smart Classroom Face Recognition System - Git Ignore

# ===========================
# Environment & Secrets
# ===========================
.env
.env.local
.env.*.local
*.pem
*.key

# ===========================
# Python
# ===========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ===========================
# Virtual Environment
# ===========================
venv/
ENV/
env/
.venv/

# ===========================
# IDE & Editors
# ===========================
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# VS Code - keep settings but ignore personal configs
!.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# ===========================
# OS Generated
# ===========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===========================
# Logs & Databases
# ===========================
*.log
*.sqlite
*.db
logs/

# ===========================
# ML Model Weights (large files)
# ===========================
# Uncomment if you don't want to track model weights
# ml/*/weights/*.onnx
# ml/*/weights/*.pth

# ===========================
# Datasets (usually too large)
# ===========================
# Uncomment if datasets should not be tracked
# datasets/

# ===========================
# Node.js / Frontend
# ===========================
node_modules/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===========================
# Testing & Coverage
# ===========================
.coverage
htmlcov/
.tox/
.pytest_cache/
.mypy_cache/

# ===========================
# Jupyter Notebooks
# ===========================
.ipynb_checkpoints/
*.ipynb

# ===========================
# Build artifacts
# ===========================
*.manifest
*.spec

# ===========================
# Large ML model weights (download separately)
# ===========================
inference_service/ml/recognition/adaface/weights/*.ckpt
inference_service/ml/recognition/adaface/weights/*.safetensors
inference_service/ml/recognition/adaface/weights/models--*
inference_service/ml/recognition/arcface/weights/*.pth
#inference_service/ml/detection/scrfd/weights/*.onnx
#inference_service/ml/detection/yolov12/weights/*.pt


# Ignore contents of specific folders but track the folders themselves
backend/datasets/data/*
!backend/datasets/data/.gitkeep

backend/datasets/backup/*
!backend/datasets/backup/.gitkeep

backend/datasets/new_persons/*
!backend/datasets/new_persons/.gitkeep

backend/datasets/face_features/*
!backend/datasets/face_features/.gitkeep
