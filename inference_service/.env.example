# Inference Service Environment Variables
# Copy to .env and customize as needed

# Server
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8010
WORKERS=2
ENV=production

# Detection: "yolov12" or "scrfd"
DETECTION_MODEL=yolov12

# Recognition: "adaface" or "arcface"
RECOGNITION_MODEL=adaface

# Preprocessing
ENABLE_PREPROCESSING=true
MIN_IMAGE_WIDTH=1920
ENABLE_UPSCALING=true
ENABLE_CLAHE=false

# Recognition threshold
CONFIDENCE_THRESHOLD=0.4

# Paths (leave empty for defaults — auto-resolves to ../backend/datasets/)
DATASETS_PATH=
FEATURE_PATH=

# Logging
LOG_LEVEL=INFO
