# Smart Classroom Face Recognition System - Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# === MongoDB Configuration ===
MONGO_DB_URL=mongodb://127.0.0.1:27017
MONGO_DB_NAME=smart_ems_db

# === API Server Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
WORKERS=1

# === Security Keys ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production
API_KEY=your-api-key-change-this

# === JWT Configuration ===
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Super Admin Configuration
SUPER_ADMIN_EMAIL=usermail@example.com
SUPER_ADMIN_PASSWORD=pass@123

# === Inference Service ===
INFERENCE_SERVICE_URL=http://localhost:8010

# === Logging ===
LOG_LEVEL=INFO
